// Metal quant scheme metadata (dispatch + canonical block traits)

QUANT_SCHEME_TRAITS(legacy_zp_none) {
    QUANT_BLOCK: { block_size: 32, group_size: 32, scale_dtype: FLOAT16, zp_dtype: NONE },
    USES_Q8K_ACTIVATION: false,
    USE_DIRECT_FP16_PATH: false
}

QUANT_SCHEME_TRAITS(legacy_zp_f16) EXTENDS legacy_zp_none {
    QUANT_BLOCK: { block_size: 32, group_size: 32, scale_dtype: FLOAT16, zp_dtype: FLOAT16 }
}

QUANT_SCHEME_TRAITS(k_256_g16_f16) EXTENDS legacy_zp_none {
    QUANT_BLOCK: { block_size: 256, group_size: 16, scale_dtype: FLOAT16, zp_dtype: NONE },
    USE_DIRECT_FP16_PATH: true
}

QUANT_SCHEME_TRAITS(k_64_g32_f16) EXTENDS legacy_zp_none {
    QUANT_BLOCK: { block_size: 64, group_size: 32, scale_dtype: FLOAT16, zp_dtype: NONE },
    USE_DIRECT_FP16_PATH: true
}

QUANT_SCHEME_TRAITS(k_256_g32_f16) EXTENDS legacy_zp_none {
    QUANT_BLOCK: { block_size: 256, group_size: 32, scale_dtype: FLOAT16, zp_dtype: NONE },
    USE_DIRECT_FP16_PATH: true
}

QUANT_SCHEME_TRAITS(k_256_g16_f32) EXTENDS legacy_zp_none {
    QUANT_BLOCK: { block_size: 256, group_size: 16, scale_dtype: FLOAT32, zp_dtype: NONE },
    USE_DIRECT_FP16_PATH: true
}

