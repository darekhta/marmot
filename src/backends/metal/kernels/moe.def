// Metal MoE kernels.

KERNEL_FAMILY(topk) {
    NAME_PATTERN: "topk_f32",
    OP: topk,
    PROFILE: NONE,
    INPUT_DTYPE: FLOAT32,
    OUTPUT_DTYPE: FLOAT32,
    ACCUM_DTYPE: FLOAT32,
    STRIDE_MODE: STRIDED,
    IMPL_FUNCTION: metal_topk_impl
}

KERNEL_FAMILY(topk_f16) {
    NAME_PATTERN: "topk_f16",
    OP: topk,
    PROFILE: NONE,
    INPUT_DTYPE: FLOAT16,
    OUTPUT_DTYPE: FLOAT16,
    ACCUM_DTYPE: FLOAT32,
    STRIDE_MODE: STRIDED,
    IMPL_FUNCTION: metal_topk_impl
}

KERNEL_FAMILY(moe_experts) {
    NAME_PATTERN: "moe_experts_f32",
    OP: moe_experts,
    PROFILE: NONE,
    INPUT_DTYPE: FLOAT32,
    OUTPUT_DTYPE: FLOAT32,
    ACCUM_DTYPE: FLOAT32,
    STRIDE_MODE: STRIDED,
    IMPL_FUNCTION: metal_moe_experts_impl
}

KERNEL_FAMILY(moe_experts_f16) {
    NAME_PATTERN: "moe_experts_f16",
    OP: moe_experts,
    PROFILE: NONE,
    INPUT_DTYPE: FLOAT16,
    OUTPUT_DTYPE: FLOAT16,
    ACCUM_DTYPE: FLOAT32,
    STRIDE_MODE: STRIDED,
    IMPL_FUNCTION: metal_moe_experts_impl
}

KERNEL_FAMILY(moe_experts_quantized) {
    AXIS(scheme): @all_quant_schemes,
    NAME_PATTERN: "moe_experts_{scheme:lower}",
    OP: moe_experts,
    PROFILE: NONE,
    INPUT_DTYPE: FLOAT32,
    OUTPUT_DTYPE: FLOAT32,
    ACCUM_DTYPE: FLOAT32,
    STRIDE_MODE: STRIDED,
    WEIGHT_QUANT: $scheme,
    QUANT_BLOCK: QUANT_SCHEME($scheme).QUANT_BLOCK,
    IMPL_FUNCTION: metal_moe_experts_impl
}

KERNEL_FAMILY(moe_experts_quantized_f16) {
    AXIS(scheme): @all_quant_schemes,
    NAME_PATTERN: "moe_experts_{scheme:lower}_f16",
    OP: moe_experts,
    PROFILE: NONE,
    INPUT_DTYPE: FLOAT16,
    OUTPUT_DTYPE: FLOAT16,
    ACCUM_DTYPE: FLOAT32,
    STRIDE_MODE: STRIDED,
    WEIGHT_QUANT: $scheme,
    QUANT_BLOCK: QUANT_SCHEME($scheme).QUANT_BLOCK,
    IMPL_FUNCTION: metal_moe_experts_impl
}
