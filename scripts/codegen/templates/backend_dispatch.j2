{# ----- Matmul Operations ----- #}
{% elif kernel.kind == 'matmul' %}
// {{ kernel.name }}: matmul
{{ m.platform_guard_start(kernel) }}
marmot_error_t marmot_{{ cfg.name }}_{{ kernel.name }}_exec(
    const void *device_ctx, const marmot_kernel_args_matmul_t *args) {
    if (args == nullptr) {
        marmot_set_error(MARMOT_ERROR_INVALID_ARGUMENT, "Matmul args not provided");
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    if (args->ctx == nullptr || args->input == nullptr || args->weight == nullptr || args->output == nullptr) {
        marmot_set_error(MARMOT_ERROR_INVALID_ARGUMENT, "Matmul args missing tensors");
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
{% if kernel.is_quantized %}
    return {{ cfg.handlers.matmul_quantized }}(device_ctx, args->input, args->weight, args->epilogue, args->output);
{% elif kernel.kernel_func %}
{% if cfg.matmul_needs_dimension_extraction %}
    const size_t N = args->input->shape.shape[0];
    const size_t K = args->input->shape.shape[1];
{% if kernel.layout == 'NN' %}
    const size_t M = args->weight->shape.shape[1];
{% else %}
    const size_t M = args->weight->shape.shape[0];
{% endif %}
    marmot_error_t status = {{ kernel.kernel_func }}(device_ctx, args->input, args->weight, N, K, M, args->output);
    if (status != MARMOT_SUCCESS) {
        return status;
    }
    return cpu_matmul_apply_epilogue(device_ctx, args->output, args->epilogue);
{% else %}
    return {{ kernel.kernel_func }}(device_ctx, args->input, args->weight, args->epilogue, args->output);
{% endif %}
{% else %}
    return {{ cfg.handlers.matmul }}(device_ctx, args->input, args->weight, args->epilogue, args->output);
{% endif %}
}
{{ m.platform_guard_end(kernel) }}

