    if (args == nullptr) {
        marmot_set_error(MARMOT_ERROR_INVALID_ARGUMENT, "Kernel args not provided");
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
{% if cfg.quantize_uses_unified_dispatcher %}
    const marmot_quant_kind_traits_t *traits = marmot_get_quant_kind_traits(args->kind);
    marmot_quant_layout_t layout = traits != nullptr ? args->layout : MARMOT_QUANT_LAYOUT_GENERIC;
    return {{ cfg.handlers.quantize }}(device_ctx, args->kind, layout, args->input, args->quant_params, args->output);
{% else %}
    const marmot_quant_kind_traits_t *traits = marmot_get_quant_kind_traits(args->kind);
    marmot_quant_layout_t layout = traits != nullptr ? args->layout : MARMOT_QUANT_LAYOUT_GENERIC;
    if (args->kind == MARMOT_QUANT_KIND_GENERIC) {
        return {{ cfg.handlers.quantize }}(device_ctx, args->input, args->quant_params, args->output);
    }
    return {{ cfg.handlers.quantize_with_kind }}(device_ctx, args->kind, layout, args->input, args->output);
{% endif %}
}
