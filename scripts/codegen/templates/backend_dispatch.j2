{# ============================================================================
   RoPE Dispatch Helper
   ============================================================================ #}
{% if has_rope_kernels %}
static marmot_error_t {{ cfg.name }}_rope_dispatch_helper(
    const void *device_ctx, const marmot_kernel_args_rope_t *unpacked
) {
    if (unpacked == nullptr || unpacked->input == nullptr ||
        unpacked->output == nullptr || unpacked->ctx == nullptr || unpacked->rope_params == nullptr) {
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }

    marmot_rope_params_t params = *unpacked->rope_params;

    // If positions tensor is provided, use it directly
    if (params.positions != nullptr) {
        return {{ cfg.handlers.rope }}(device_ctx, unpacked->input, &params, unpacked->output);
    }

    // Otherwise generate positions from n_past
    const size_t seq_len = unpacked->input->shape.ndim >= 2 ?
        unpacked->input->shape.shape[unpacked->input->shape.ndim - 2] : 1;

{% if cfg.name == 'cpu' %}
    {{ cfg.context_type }} *ctx = ({{ cfg.context_type }} *)device_ctx;
    int32_t *positions_data = cpu_get_rope_positions_scratch(ctx, seq_len);
    if (positions_data == nullptr) {
        marmot_set_error(MARMOT_ERROR_OUT_OF_MEMORY, "Failed to get positions scratch buffer for RoPE");
        return MARMOT_ERROR_OUT_OF_MEMORY;
    }
{% else %}
    int32_t *positions_data = (int32_t *)malloc(seq_len * sizeof(int32_t));
    if (positions_data == nullptr) {
        marmot_set_error(MARMOT_ERROR_OUT_OF_MEMORY, "Failed to allocate positions for RoPE");
        return MARMOT_ERROR_OUT_OF_MEMORY;
    }
{% endif %}

    for (size_t i = 0; i < seq_len; ++i) {
        positions_data[i] = (int32_t)(unpacked->n_past + i);
    }

    size_t pos_shape[1] = {seq_len};
    marmot_tensor_t *positions = marmot_tensor_create(unpacked->ctx, pos_shape, 1, MARMOT_DTYPE_INT32);
    if (positions == nullptr) {
{% if cfg.name != 'cpu' %}
        free(positions_data);
{% endif %}
        marmot_set_error(MARMOT_ERROR_OUT_OF_MEMORY, "Failed to create positions tensor for RoPE");
        return MARMOT_ERROR_OUT_OF_MEMORY;
    }

    marmot_error_t err = marmot_tensor_copy_from_host_buffer(
        unpacked->ctx, positions, positions_data, seq_len * sizeof(int32_t)
    );
{% if cfg.name != 'cpu' %}
    free(positions_data);
{% endif %}
    if (err != MARMOT_SUCCESS) {
        marmot_tensor_destroy(positions);
        return err;
    }

    params.positions = positions;
    err = {{ cfg.handlers.rope }}(device_ctx, unpacked->input, &params, unpacked->output);
    marmot_tensor_destroy(positions);
    return err;
}

