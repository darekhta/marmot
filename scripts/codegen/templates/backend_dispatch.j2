{% elif kernel.kind == 'qkv' %}
// {{ kernel.name }}: QKV projection
{{ m.platform_guard_start(kernel) }}
marmot_error_t marmot_{{ cfg.name }}_{{ kernel.name }}_exec(
    const void *device_ctx, const marmot_kernel_args_qkv_t *args) {
    if (args == nullptr) {
        marmot_set_error(MARMOT_ERROR_INVALID_ARGUMENT, "QKV args not provided");
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    if (args->ctx == nullptr || args->input == nullptr || args->wq == nullptr ||
        args->wk == nullptr || args->wv == nullptr || args->out_q == nullptr ||
        args->out_k == nullptr || args->out_v == nullptr) {
        marmot_set_error(MARMOT_ERROR_INVALID_ARGUMENT, "QKV args missing tensors");
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    marmot_matmul_qkv_desc_t desc = marmot_matmul_qkv_desc_default();
    desc.input = args->input;
    desc.layout = MARMOT_QKV_LAYOUT_SEPARATE;
    desc.separate.wq = args->wq;
    desc.separate.wk = args->wk;
    desc.separate.wv = args->wv;
    desc.separate.bq = args->bq;
    desc.separate.bk = args->bk;
    desc.separate.bv = args->bv;
    desc.epilogue = args->epilogue;
    desc.rope_params = args->rope_params;
    desc.out_q = args->out_q;
    desc.out_k = args->out_k;
    desc.out_v = args->out_v;
{% if kernel.kernel_func %}
    return {{ kernel.kernel_func }}(device_ctx, &desc);
{% elif kernel.is_quantized %}
    return {{ cfg.handlers.qkv }}_{{ kernel.weight_quant }}(device_ctx, &desc);
{% else %}
    return {{ cfg.handlers.qkv }}_{{ kernel.input_dtype }}(device_ctx, &desc);
{% endif %}
}
{{ m.platform_guard_end(kernel) }}

