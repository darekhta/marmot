        .num_inputs = count,
        .output = marmot_bc_reg(regs, output_idx),
        .axis = axis,
    };
{% elif kernel.op == 'slice' %}
    uint16_t input_idx = marmot_bc_read_u16(&pc);
    uint16_t output_idx = marmot_bc_read_u16(&pc);
    uint32_t starts_offset = marmot_bc_read_u32(&pc);
    uint32_t sizes_offset = marmot_bc_read_u32(&pc);
    const size_t *starts = (const size_t *)marmot_bc_const_data(const_pool, starts_offset, "Null const pool for slice starts");
    const size_t *sizes = (const size_t *)marmot_bc_const_data(const_pool, sizes_offset, "Null const pool for slice sizes");
    if (starts_offset != MARMOT_BC_INVALID_OFFSET && starts == nullptr) {
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    if (sizes_offset != MARMOT_BC_INVALID_OFFSET && sizes == nullptr) {
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    marmot_kernel_args_slice_t args = {
        .ctx = ctx,
        .input = marmot_bc_reg(regs, input_idx),
        .output = marmot_bc_reg(regs, output_idx),
        .starts = starts,
        .sizes = sizes,
    };
{% elif kernel.op == 'gather_rows' or kernel.op == 'scatter_u64_to_i32' %}
    (void)const_pool;
    uint16_t input_idx = marmot_bc_read_u16(&pc);
    uint16_t indices_idx = marmot_bc_read_u16(&pc);
    uint16_t output_idx = marmot_bc_read_u16(&pc);
    marmot_kernel_args_gather_rows_t args = {
        .ctx = ctx,
        .input = marmot_bc_reg(regs, input_idx),
        .indices = marmot_bc_reg(regs, indices_idx),
        .output = marmot_bc_reg(regs, output_idx),
    };
{% elif kernel.op == 'quantize' %}
    uint16_t input_idx = marmot_bc_read_u16(&pc);
    uint32_t params_offset = marmot_bc_read_u32(&pc);
    uint16_t output_idx = marmot_bc_read_u16(&pc);
    marmot_quant_kind_t kind = (marmot_quant_kind_t)marmot_bc_read_u32(&pc);
    marmot_quant_layout_t layout = (marmot_quant_layout_t)marmot_bc_read_u32(&pc);
    const marmot_quant_params_t *params = (const marmot_quant_params_t *)marmot_bc_const_data(
        const_pool, params_offset, "Null const pool for quant params"
    );
    if (params_offset != MARMOT_BC_INVALID_OFFSET && params == nullptr) {
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    marmot_kernel_args_quantize_t args = {
        .ctx = ctx,
        .input = marmot_bc_reg(regs, input_idx),
        .quant_params = params,
        .output = marmot_bc_reg(regs, output_idx),
        .kind = kind,
        .layout = layout,
    };
{% elif kernel.op == 'dequantize' %}
    (void)const_pool;
    uint16_t input_idx = marmot_bc_read_u16(&pc);
    uint16_t output_idx = marmot_bc_read_u16(&pc);
    marmot_quant_kind_t kind = (marmot_quant_kind_t)marmot_bc_read_u32(&pc);
    marmot_quant_layout_t layout = (marmot_quant_layout_t)marmot_bc_read_u32(&pc);
    marmot_kernel_args_dequantize_t args = {
        .ctx = ctx,
        .input = marmot_bc_reg(regs, input_idx),
        .output = marmot_bc_reg(regs, output_idx),
        .kind = kind,
        .layout = layout,
    };
{% elif kernel.op == 'compute_quant_params' %}
    uint16_t tensor_idx = marmot_bc_read_u16(&pc);
    marmot_dtype_t target_dtype = (marmot_dtype_t)marmot_bc_read_u32(&pc);
    size_t block_size = (size_t)marmot_bc_read_u64(&pc);
    uint32_t out_offset = marmot_bc_read_u32(&pc);
    marmot_quant_params_t *out_params = (marmot_quant_params_t *)marmot_bc_const_ptr_mut(
        const_pool, out_offset, "Null const pool for quant params output"
    );
    if (out_offset != MARMOT_BC_INVALID_OFFSET && out_params == nullptr) {
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    marmot_kernel_args_compute_qparams_t args = {
        .ctx = ctx,
        .tensor = marmot_bc_reg(regs, tensor_idx),
        .target_dtype = target_dtype,
        .block_size = block_size,
        .out_params = out_params,
    };
{% elif kernel.op == 'embedding' %}
    (void)const_pool;
    uint16_t weights_idx = marmot_bc_read_u16(&pc);
    uint16_t token_ids_idx = marmot_bc_read_u16(&pc);
    uint16_t out_idx = marmot_bc_read_u16(&pc);
    marmot_dtype_t dtype_out = (marmot_dtype_t)marmot_bc_read_u32(&pc);
    float scale = marmot_bc_read_f32(&pc);
    int32_t padding_id = (int32_t)marmot_bc_read_u32(&pc);
    bool bounds_check = marmot_bc_read_u8(&pc) != 0;
    bool prefer_gpu = marmot_bc_read_u8(&pc) != 0;
    bool allow_decode = marmot_bc_read_u8(&pc) != 0;
    marmot_kernel_args_embedding_t args = {
        .ctx = ctx,
        .weights = marmot_bc_reg(regs, weights_idx),
        .token_ids = marmot_bc_reg(regs, token_ids_idx),
        .out = marmot_bc_reg(regs, out_idx),
        .dtype_out = dtype_out,
        .scale = scale,
        .padding_id = padding_id,
        .bounds_check = bounds_check,
        .prefer_gpu_private = prefer_gpu,
        .allow_quant_decode_on_the_fly = allow_decode,
    };
{% elif kernel.op == 'convert' %}
    uint32_t dst_offset = marmot_bc_read_u32(&pc);
    uint32_t src_offset = marmot_bc_read_u32(&pc);
    size_t n = (size_t)marmot_bc_read_u64(&pc);
    marmot_dtype_t dst_dtype = (marmot_dtype_t)marmot_bc_read_u32(&pc);
    marmot_dtype_t src_dtype = (marmot_dtype_t)marmot_bc_read_u32(&pc);
    void *dst = marmot_bc_const_ptr_mut(const_pool, dst_offset, "Null const pool for convert dst");
    const void *src = marmot_bc_const_ptr(const_pool, src_offset, "Null const pool for convert src");
    if (dst_offset != MARMOT_BC_INVALID_OFFSET && dst == nullptr) {
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    if (src_offset != MARMOT_BC_INVALID_OFFSET && src == nullptr) {
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
    marmot_kernel_args_convert_t args = {
        .ctx = ctx,
        .dst = dst,
        .src = src,
        .n = n,
        .dst_dtype = dst_dtype,
        .src_dtype = src_dtype,
    };
{% elif kernel.op == 'vec_dot' %}
    uint16_t input_idx = marmot_bc_read_u16(&pc);
    uint16_t weight_idx = marmot_bc_read_u16(&pc);
    uint16_t output_idx = marmot_bc_read_u16(&pc);
    uint32_t desc_offset = marmot_bc_read_u32(&pc);
    uint32_t result_offset = marmot_bc_read_u32(&pc);
    marmot_vec_dot_descriptor_t desc;
    const marmot_vec_dot_descriptor_t *desc_ptr = nullptr;
    float *result = nullptr;
    if (desc_offset != MARMOT_BC_INVALID_OFFSET) {
        desc_ptr = (const marmot_vec_dot_descriptor_t *)marmot_bc_const_data(
            const_pool, desc_offset, "Null const pool for vec dot descriptor"
        );
        result = (float *)marmot_bc_const_ptr_mut(const_pool, result_offset, "Null const pool for vec dot result");
        if (desc_ptr == nullptr || result == nullptr) {
            return MARMOT_ERROR_INVALID_ARGUMENT;
        }
    } else {
        const marmot_tensor_t *input = marmot_bc_reg(regs, input_idx);
        const marmot_tensor_t *weight = marmot_bc_reg(regs, weight_idx);
        marmot_tensor_t *output = marmot_bc_reg(regs, output_idx);
        if (input == nullptr || weight == nullptr || output == nullptr || output->data == nullptr) {
            marmot_set_error(MARMOT_ERROR_INVALID_ARGUMENT, "Vec dot tensors missing");
            return MARMOT_ERROR_INVALID_ARGUMENT;
        }
        if (marmot_vec_dot_descriptor_from_tensors(input, weight, &desc) != MARMOT_SUCCESS) {
            return MARMOT_ERROR_INVALID_ARGUMENT;
        }
        desc_ptr = &desc;
        result = (float *)output->data;
    }
    marmot_kernel_args_vec_dot_t args = {
        .ctx = ctx,
        .desc = desc_ptr,
        .result = result,
    };
{% else %}
    (void)const_pool;
    marmot_set_error(MARMOT_ERROR_NOT_IMPLEMENTED, "Bytecode executor not available for op");
    return MARMOT_ERROR_NOT_IMPLEMENTED;
{% endif %}
    marmot_error_t status = marmot_{{ backend }}_{{ kernel.name }}_exec(device_ctx, &args);
    if (concat_inputs != nullptr) {
        free(concat_inputs);
    }
    return status;
}
{% if kernel.exec_guard != "1" %}#endif
{% endif %}

{% endfor %}

