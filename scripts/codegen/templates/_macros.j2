{# =============================================================================
   Shared Macros for Marmot Code Generation

   These macros provide reusable patterns across all templates:
   - File headers
   - Platform guards
   - Argument validation
   - Common kernel implementation patterns
   ============================================================================= #}

{# File header with license and autogen notice #}
{% macro file_header(generator="gen_kernels.py") %}
// SPDX-License-Identifier: MIT
// This file was autogenerated by scripts/codegen/{{ generator }}; DO NOT EDIT.
{% endmacro %}

{# Platform guard start (for kernels with platform requirements) #}
{% macro platform_guard_start(kernel) %}
{% if kernel.platform_guard and kernel.platform_guard != "1" %}#if {{ kernel.platform_guard }}
{% endif %}
{% if kernel.requires_fp8 %}#if MARMOT_ENABLE_FP8
{% endif %}
{% endmacro %}

{# Platform guard end #}
{% macro platform_guard_end(kernel) %}
{% if kernel.requires_fp8 %}#endif
{% endif %}
{% if kernel.platform_guard and kernel.platform_guard != "1" %}#endif
{% endif %}
{% endmacro %}

{# Wrapper for entire file (Metal uses #ifdef __APPLE__) #}
{% macro file_guard_start(cfg) %}
{% if cfg.platform_guard_wrapper %}
{{ cfg.platform_guard_wrapper }}

{% endif %}
{% endmacro %}

{% macro file_guard_end(cfg) %}
{% if cfg.platform_guard_wrapper %}

#endif // {{ cfg.platform_guard_wrapper.split()[1] if cfg.platform_guard_wrapper.startswith('#ifdef') else '' }}
{% endif %}
{% endmacro %}

{# C++ extern "C" guards #}
{% macro extern_c_start(cfg) %}
{% if cfg.needs_extern_c %}
#ifdef __cplusplus
extern "C" {
#endif

{% endif %}
{% endmacro %}

{% macro extern_c_end(cfg) %}
{% if cfg.needs_extern_c %}

#ifdef __cplusplus
} // extern "C"
#endif
{% endif %}
{% endmacro %}

{# Standard argument validation #}
{% macro validate_args(error_msg) %}
    if (args == nullptr) {
        marmot_set_error(MARMOT_ERROR_INVALID_ARGUMENT, "{{ error_msg }}");
        return MARMOT_ERROR_INVALID_ARGUMENT;
    }
{% endmacro %}

{# Unpack kernel arguments #}
{% macro unpack_args(args_type, var_name="unpacked", init_zero=false) %}
    marmot_kernel_args_{{ args_type }}_t {{ var_name }}{% if init_zero %} = {}{% endif %};
    marmot_kernel_args_{{ args_type }}_unpack({% if init_zero %}(void *const *){% endif %}args, &{{ var_name }});
{% endmacro %}

{# Standard kernel implementation wrapper #}
{% macro kernel_impl_start(kernel, cfg) %}
{{ platform_guard_start(kernel) }}
static marmot_error_t {{ kernel.impl_name }}(const void *device_ctx, void **args) {
{{ validate_args(kernel.kind | capitalize ~ " args not provided") }}
{% endmacro %}

{% macro kernel_impl_end(kernel, cfg) %}
}
{{ platform_guard_end(kernel) }}
{% endmacro %}

{# Dispatch switch case #}
{% macro dispatch_case(kernel) %}
{{ platform_guard_start(kernel) }}
    case {{ kernel.kernel_id }}:
        return {{ kernel.impl_name }}(device_ctx, args);
{{ platform_guard_end(kernel) }}
{% endmacro %}

{# Standard dispatch function signature #}
{% macro dispatch_fn_signature(cfg, fn_suffix="") %}
marmot_error_t marmot_{{ cfg.name }}_dispatch{{ fn_suffix }}(
    marmot_kernel_id_t kernel_id,
    const void *device_ctx,
    void **args
)
{% endmacro %}
